{
  "uid": "grpc-red",
  "title": "gRPC RED (audit / queue)",
  "tags": ["grpc", "red", "audit-api", "queue-api"],
  "timezone": "",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(rpc_server_call_duration_seconds_count, service_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "RPC / sec by service + method",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name, rpc_method) (rate(rpc_server_call_duration_seconds_count{service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{service_name}} {{rpc_method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Errors / sec by status code (excluding OK)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name, rpc_grpc_status_code) (rate(rpc_server_call_duration_seconds_count{service_name=~\"$service\",rpc_grpc_status_code!=\"0\"}[1m]))",
          "legendFormat": "{{service_name}} code={{rpc_grpc_status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p50 / p95 / p99 duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(rpc_server_call_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "{{service_name}} p50",
          "refId": "A"
        },
        {
          "expr": "service:rpc_server_call_duration_seconds:p95_5m{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} p95",
          "refId": "B"
        },
        {
          "expr": "service:rpc_server_call_duration_seconds:p99_5m{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top methods by p95 (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(20, histogram_quantile(0.95, sum by (le, service_name, rpc_method) (rate(rpc_server_call_duration_seconds_bucket{service_name=~\"$service\"}[5m]))))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "Value": "p95 (s)" }
          }
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 }
    }
  ]
}
