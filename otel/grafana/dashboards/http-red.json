{
  "uid": "http-red",
  "title": "HTTP RED (auth)",
  "tags": ["http", "red", "auth-api"],
  "timezone": "",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(http_server_request_duration_seconds_count, service_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Requests / sec by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (http_route, http_request_method) (rate(http_server_request_duration_seconds_count{service_name=~\"$service\"}[1m]))",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Errors / sec by status class (4xx, 5xx)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (service_name, http_response_status_code) (rate(http_server_request_duration_seconds_count{service_name=~\"$service\",http_response_status_code=~\"4..|5..\"}[1m]))",
          "legendFormat": "{{service_name}} code={{http_response_status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "p50 / p95 / p99 duration",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, service_name) (rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])))",
          "legendFormat": "{{service_name}} p50",
          "refId": "A"
        },
        {
          "expr": "service:http_server_request_duration_seconds:p95_5m{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} p95",
          "refId": "B"
        },
        {
          "expr": "service:http_server_request_duration_seconds:p99_5m{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}} p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 7 }
    },
    {
      "id": 4,
      "type": "table",
      "title": "Top routes by request volume (5m)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(20, sum by (http_route, http_request_method, service_name) (increase(http_server_request_duration_seconds_count{service_name=~\"$service\"}[5m])))",
          "instant": true,
          "format": "table",
          "refId": "A"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "Time": true, "__name__": true, "job": true, "instance": true },
            "renameByName": { "Value": "requests (5m)" }
          }
        }
      ],
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 7 }
    }
  ]
}
