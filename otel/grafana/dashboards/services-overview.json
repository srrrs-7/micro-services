{
  "uid": "services-overview",
  "title": "Services Overview",
  "tags": ["go", "otel", "red"],
  "timezone": "",
  "schemaVersion": 41,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-15m", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(service_name)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Go runtime",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Goroutines",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_runtime_go_goroutines{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 1 }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Heap in-use",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_runtime_go_mem_heap_inuse_bytes{service_name=~\"$service\"}",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 1 }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "GC pauses (rate)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(process_runtime_go_gc_count_total{service_name=~\"$service\"}[1m])",
          "legendFormat": "{{service_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 1 }
    },
    {
      "id": 10,
      "type": "row",
      "title": "HTTP (auth-api)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 8 }
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "HTTP requests / sec by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=~\"$service\"}[1m])) by (http_route, http_request_method)",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 9 }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "HTTP p95 duration by route",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])) by (le, http_route, http_request_method))",
          "legendFormat": "{{http_request_method}} {{http_route}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 9 }
    },
    {
      "id": 20,
      "type": "row",
      "title": "gRPC (audit-api / queue-api)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 }
    },
    {
      "id": 21,
      "type": "timeseries",
      "title": "gRPC RPC / sec by status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(rpc_server_duration_milliseconds_count{service_name=~\"$service\"}[1m])) by (service_name, rpc_grpc_status_code)",
          "legendFormat": "{{service_name}} code={{rpc_grpc_status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 17 }
    },
    {
      "id": 22,
      "type": "timeseries",
      "title": "gRPC p95 duration by method",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(rpc_server_duration_milliseconds_bucket{service_name=~\"$service\"}[5m])) by (le, service_name, rpc_method))",
          "legendFormat": "{{service_name}} {{rpc_method}}",
          "refId": "A"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 17 }
    }
  ]
}
